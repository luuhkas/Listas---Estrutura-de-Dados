{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build active C file",
            "type": "shell",
            "command": "clang",
            "args": [
                "${file}",
                "-g",
                "-o",
                "${fileDirname}/../build/${fileBasenameNoExtension}"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "run active C file",
            "type": "shell",
            "command": "/bin/bash",
            "args": [
                "-c",
                "mkdir -p \"${fileDirname}/../build\" && clang \"${file}\" -g -o \"${fileDirname}/../build/${fileBasenameNoExtension}\" && \"${fileDirname}/../build/${fileBasenameNoExtension}\""
            ],
            "group": "none"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: clang arquivo de build ativo",
            "command": "/usr/bin/clang",
            "args": [
                "-fcolor-diagnostics",
                "-fansi-escape-codes",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Tarefa gerada pelo Depurador."
        }
    ]
}
